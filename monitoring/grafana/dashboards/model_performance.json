{
  "title": "Model Performance Dashboard",
  "uid": "fraud-model-perf",
  "tags": ["fraud", "ml", "model"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Fraud Recall (KEY METRIC)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "fraud_model_recall",
        "legendFormat": "Recall"
      }],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            {"color": "red", "value": 0},
            {"color": "yellow", "value": 0.65},
            {"color": "green", "value": 0.75}
          ]
        }
      },
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "False Positive Rate",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "fraud_false_positive_rate",
        "legendFormat": "FPR"
      }],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            {"color": "green", "value": 0},
            {"color": "yellow", "value": 0.1},
            {"color": "red", "value": 0.2}
          ]
        }
      },
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "Data Drift Score",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "expr": "fraud_data_drift_score",
        "legendFormat": "Drift"
      }],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            {"color": "green", "value": 0},
            {"color": "yellow", "value": 0.2},
            {"color": "red", "value": 0.35}
          ]
        }
      },
      "datasource": "Prometheus"
    },
    {
      "id": 4,
      "title": "Fraud vs Legit Predictions",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "targets": [
        {"expr": "fraud_predictions_total{prediction=\"fraud\"}", "legendFormat": "Fraud"},
        {"expr": "fraud_predictions_total{prediction=\"legit\"}", "legendFormat": "Legit"}
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "Recall Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{
        "expr": "fraud_model_recall",
        "legendFormat": "Recall"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 0.65},
              {"color": "green", "value": 0.75}
            ]
          },
          "min": 0, "max": 1
        }
      },
      "datasource": "Prometheus"
    },
    {
      "id": 6,
      "title": "Prediction Confidence Distribution",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{
        "expr": "rate(fraud_prediction_confidence_bucket[5m])",
        "legendFormat": "le={{le}}"
      }],
      "datasource": "Prometheus"
    }
  ]
}
