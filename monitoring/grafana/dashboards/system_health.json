{
  "title": "System Health Dashboard",
  "uid": "fraud-system-health",
  "tags": ["fraud", "system", "api"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "expr": "rate(fraud_api_requests_total[1m])",
        "legendFormat": "{{method}} {{endpoint}} {{status}}"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "API p95 Latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(fraud_api_request_latency_seconds_bucket[5m]))",
        "legendFormat": "p95 latency"
      }],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "targets": [{
        "expr": "rate(fraud_api_requests_total{status=\"500\"}[5m])",
        "legendFormat": "Error Rate"
      }],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            {"color": "green", "value": 0},
            {"color": "red", "value": 0.01}
          ]
        }
      },
      "datasource": "Prometheus"
    },
    {
      "id": 4,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
        "legendFormat": "CPU %"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "Memory %"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
      "datasource": "Prometheus"
    }
  ]
}
